{
  "manifest_version": 3,
  "name": "Focus Blocker",
  "version": "1.0.0",
  "description": "Block distracting sites during Pomodoro-style focus sessions.",
  "permissions": ["storage", "alarms", "declarativeNetRequest", "notifications"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Blocker"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["bunny-core.js", "bunny.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "fonts/PressStart2P.ttf"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
